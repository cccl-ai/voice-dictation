#!/usr/bin/env python3
"""
Background listener for voice dictation hotkeys (works on Wayland).
Communicates with dictate-daemon via control file.

Hotkeys:
- Caps Lock tap (<300ms): Toggle mode (start/stop)
- Caps Lock hold (>300ms): Push-to-talk (hold to record)
- Ctrl+Shift+Space: Toggle mode (legacy)
"""

import os
import threading
import time
import evdev
from evdev import ecodes

CONTROL_FILE = "/tmp/dictation_control"
PID_FILE = "/tmp/dictation.pid"
HOLD_THRESHOLD = 0.3  # seconds - hold longer than this for push-to-talk

# Find keyboard device (skip virtual devices like ydotoold)
def find_keyboard():
    devices = [evdev.InputDevice(path) for path in evdev.list_devices()]
    for device in devices:
        # Skip virtual devices
        if 'virtual' in device.name.lower() or 'ydotool' in device.name.lower():
            continue
        caps = device.capabilities()
        if ecodes.EV_KEY in caps:
            keys = caps[ecodes.EV_KEY]
            # Check if it has typical keyboard keys
            if ecodes.KEY_SPACE in keys and ecodes.KEY_LEFTCTRL in keys:
                return device
    return None

keyboard = find_keyboard()
if not keyboard:
    print("No keyboard found!")
    exit(1)

print(f"Using keyboard: {keyboard.name}", flush=True)
print("Dictation listener started.", flush=True)
print(f"  Caps Lock tap (<{int(HOLD_THRESHOLD*1000)}ms):  Toggle mode (start/stop)", flush=True)
print(f"  Caps Lock hold (>{int(HOLD_THRESHOLD*1000)}ms): Push-to-talk (hold to record)", flush=True)
print("  Ctrl+Shift+Space: Toggle mode (legacy)", flush=True)
print("Press Ctrl+C to stop.", flush=True)

# Track modifier state
ctrl_pressed = False
shift_pressed = False

# Caps Lock state for tap vs hold detection
capslock_down_time = None
capslock_recording = False
capslock_timer = None

def send_control(action):
    """Send control signal to daemon."""
    try:
        with open(CONTROL_FILE, "w") as f:
            f.write(action)
        return True
    except Exception as e:
        print(f"Error writing control file: {e}", flush=True)
        return False

def start_push_to_talk():
    """Called after hold threshold - start recording for push-to-talk."""
    global capslock_recording
    if capslock_down_time is not None:  # Key still held
        capslock_recording = True
        if send_control("start"):
            print("Push-to-talk: start (held)", flush=True)

for event in keyboard.read_loop():
    if event.type == ecodes.EV_KEY:
        key = event.code
        state = event.value  # 1 = pressed, 0 = released, 2 = held

        # Track Ctrl
        if key in (ecodes.KEY_LEFTCTRL, ecodes.KEY_RIGHTCTRL):
            ctrl_pressed = state > 0

        # Track Shift
        if key in (ecodes.KEY_LEFTSHIFT, ecodes.KEY_RIGHTSHIFT):
            shift_pressed = state > 0

        # Ctrl+Shift+Space: Toggle mode (legacy)
        if key == ecodes.KEY_SPACE and state == 1:
            if ctrl_pressed and shift_pressed:
                is_recording = os.path.isfile(PID_FILE)
                action = "stop" if is_recording else "start"
                if send_control(action):
                    print(f"Toggle mode: {action}", flush=True)

        # Caps Lock: Tap vs Hold detection
        if key == ecodes.KEY_CAPSLOCK:
            if state == 1:  # Key down
                capslock_down_time = time.time()
                capslock_recording = False
                # Start timer for push-to-talk threshold
                capslock_timer = threading.Timer(HOLD_THRESHOLD, start_push_to_talk)
                capslock_timer.start()

            elif state == 0:  # Key up
                # Cancel timer if still running
                if capslock_timer:
                    capslock_timer.cancel()
                    capslock_timer = None

                if capslock_recording:
                    # Was push-to-talk, stop recording
                    if send_control("stop"):
                        print("Push-to-talk: stop", flush=True)
                elif capslock_down_time is not None:
                    # Was a quick tap, toggle mode
                    is_recording = os.path.isfile(PID_FILE)
                    action = "stop" if is_recording else "start"
                    if send_control(action):
                        print(f"Tap toggle: {action}", flush=True)

                capslock_down_time = None
                capslock_recording = False
